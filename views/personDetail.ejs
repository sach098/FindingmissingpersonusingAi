<%- include("partials/header") %>
<link rel="stylesheet" href="/css/pages/search.css">
<link rel="stylesheet" href="/css/common/footer.css">
<link rel="stylesheet" href="/css/common/header.css">

<div style="max-width:700px;margin:40px auto;padding:0 20px;">

  <a href="/" style="color:#2563eb;text-decoration:none;">← Back to Home</a>

  <div style="background:white;border-radius:12px;overflow:hidden;
    box-shadow:0 2px 12px rgba(0,0,0,0.1);margin-top:20px;">

    <!-- Photo -->
    <% if (person.photo) { %>
      <img src="/uploads/<%= person.photo %>"
        style="width:100%;height:350px;object-fit:cover;">
    <% } %>

    <div style="padding:30px;">

      <!-- Name + Status -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h1 style="margin:0;font-size:28px;"><%= person.name %></h1>
        <span style="background:#fef2f2;color:#dc2626;padding:6px 16px;
          border-radius:20px;font-weight:600;">⚠ Missing</span>
      </div>

      <!-- Details Grid -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">

        <% if (person.age) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Age</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.age %></p>
        </div>
        <% } %>

        <% if (person.gender) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Gender</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.gender %></p>
        </div>
        <% } %>

        <% if (person.lastLocation) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Last Seen Location</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.lastLocation %></p>
        </div>
        <% } %>

        <% if (person.lastSeenDate) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Last Seen Date</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.lastSeenDate %></p>
        </div>
        <% } %>

        <% if (person.height) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Height</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.height %></p>
        </div>
        <% } %>

        <% if (person.complexion) { %>
        <div style="background:#f8fafc;padding:14px;border-radius:8px;">
          <p style="color:#6b7280;font-size:12px;margin:0;">Complexion</p>
          <p style="font-weight:600;margin:4px 0 0;"><%= person.complexion %></p>
        </div>
        <% } %>

      </div>

      <!-- Description -->
      <% if (person.description) { %>
      <div style="background:#f8fafc;padding:16px;border-radius:8px;margin-bottom:20px;">
        <p style="color:#6b7280;font-size:12px;margin:0 0 6px;">Description</p>
        <p style="margin:0;"><%= person.description %></p>
      </div>
      <% } %>

      <!-- Contact -->
      <% if (person.phone || person.email) { %>
      <div style="background:#f0fdf4;padding:16px;border-radius:8px;border:1px solid #86efac;">
        <h3 style="margin:0 0 12px;color:#15803d;">📞 Contact Information</h3>
        <% if (person.reporterName) { %><p style="margin:4px 0;">👤 <%= person.reporterName %></p><% } %>
        <% if (person.phone) { %><p style="margin:4px 0;">📱 <%= person.phone %></p><% } %>
        <% if (person.email) { %><p style="margin:4px 0;">✉️ <%= person.email %></p><% } %>
      </div>
      <% } %>

    </div>
  </div>
</div>

<%- include("partials/footer") %>
